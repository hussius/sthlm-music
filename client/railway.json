{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "/bin/bash -l -c 'echo Starting && exec caddy run --config /app/Caddyfile --adapter caddyfile'",
    "healthcheckPath": "/",
    "healthcheckTimeout": 60
  }
}
